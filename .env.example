# =============================================================
#  SISTEMA DE DIAGNÓSTICO DAS SECRETARIAS
#  Copie este arquivo para .env e preencha os valores
#  NUNCA commite o .env no git
# =============================================================

# --- AMBIENTE ---
NODE_ENV=development

# --- POSTGRES ---
POSTGRES_DB=diagnostico
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque_esta_senha_forte

# --- JWT ---
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=gere_um_secret_forte_aqui
JWT_EXPIRES_IN=15m

JWT_REFRESH_SECRET=gere_outro_secret_diferente_aqui
JWT_REFRESH_EXPIRES_IN=7d

# --- FRONTEND ---
NEXT_PUBLIC_API_URL=http://localhost/api
